rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

   // Tasks collection
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || request.auth.token.admin == true);
      // Subcollection: komentáře – čtení/vytvoření kdokoli, úprava/smazání jen autor
      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow update, delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }
    }
    
    // Users collection - Firebase Auth users, each user can read/write own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Boards collection
    match /boards/{boardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
        && resource.data.members[request.auth.uid] != null;
    }
    
    // Projects collection - createdBy is Firebase Auth uid
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || request.auth.token.admin == true);
    }

    // Čas strávený uživatelem u projektu (timer) – vlastní záznamy; majitel projektu vidí aktivitu všech v projektu
    match /userProjectTime/{docId} {
      allow read: if request.auth != null
        && (resource == null
            || resource.data.userId == request.auth.uid
            || (resource.data.keys().hasAny(['projectId'])
                && exists(/databases/$(database)/documents/projects/$(resource.data.projectId))
                && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.createdBy == request.auth.uid));
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
    
    // Catch-all pravidlo - pouze pro ostatní kolekce
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2025, 11, 20);
    }
  }
}