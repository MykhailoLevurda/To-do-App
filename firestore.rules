rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Pomocné funkce pro role v projektu (Owner / Admin / Member) ---
    function getProject(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }
    function isProjectOwner(projectId) {
      return getProject(projectId).createdBy == request.auth.uid;
    }
    function isProjectAdmin(projectId) {
      return getProject(projectId).get('memberRoles', {})[request.auth.uid] == 'admin';
    }
    function isProjectMember(projectId) {
      let p = getProject(projectId);
      return p.createdBy == request.auth.uid || p.get('memberRoles', {})[request.auth.uid] != null;
    }
    function isProjectOwnerOrAdmin(projectId) {
      return isProjectOwner(projectId) || isProjectAdmin(projectId);
    }

    // Tasks – čtení/vytvoření pokud jsi člen projektu; úprava/smazání pokud Owner/Admin nebo autor úkolu
    match /tasks/{taskId} {
      allow read: if request.auth != null
        && (resource == null || isProjectMember(resource.data.projectId));
      allow create: if request.auth != null
        && isProjectMember(request.resource.data.projectId);
      allow update, delete: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || isProjectOwnerOrAdmin(resource.data.projectId));
      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow update, delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }
    }

    // Users – každý jen svůj dokument
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Boards
    match /boards/{boardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.members[request.auth.uid] != null;
    }

    // Projects – Owner = createdBy; Admin = memberRoles[uid] == 'admin'; Member = v memberRoles nebo createdBy
    // update také: uživatel přijímá pozvánku (jeho email je v pendingInviteEmails)
    match /projects/{projectId} {
      allow read: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || resource.data.get('memberRoles', {})[request.auth.uid] != null
            || request.auth.token.email in resource.data.get('pendingInviteEmails', []));
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || resource.data.get('memberRoles', {})[request.auth.uid] == 'admin'
            || request.auth.token.email in resource.data.get('pendingInviteEmails', []));
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // Čas u projektu – čtení vlastní záznamy nebo Owner/Admin projektu
    match /userProjectTime/{docId} {
      allow read: if request.auth != null
        && (resource == null
            || resource.data.userId == request.auth.uid
            || (resource.data.keys().hasAny(['projectId'])
                && exists(/databases/$(database)/documents/projects/$(resource.data.projectId))
                && isProjectOwnerOrAdmin(resource.data.projectId)));
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2025, 11, 20);
    }
  }
}
